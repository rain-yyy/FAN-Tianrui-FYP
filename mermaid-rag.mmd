flowchart TB
 subgraph Ingest["Ingestion Pipeline"]
        E["Tree-sitter AST-aware Chunking"]
        C["File Filtering
    Exclude Binary and env Files"]
        F["RecursiveCharacterTextSplitter\nchunk_size=2000 · overlap=200"]
        G["LangChain Document"]
        I["baai/bge-m3
        Batch Embedding batch_size=300"]
        J["FAISS Index
        /vector_store/code/ & /text/"]
  end
 subgraph GraphRAG["GraphRAG Community Index"]
        K1["Nodes: file · class · function"]
        K["CodeGraphBuilder
        Tree-sitter + NetworkX DiGraph"]
        K2["Edges: contains · calls · imports · inherits · references"]
        L["CommunityEngine
        Leiden Algorithm"]
        M["LLM Generate community_summary"]
        N[("graphrag_communities.json")]
  end
 subgraph WikiGen["Wiki Generation Pipeline"]
        WS["Wiki Structure Generation"]
        B3["RepoMap Code Structure"]
        WC["Wiki Content Generation"]
  end
 subgraph Retrieval["Retrieval Pipeline"]
        HyDE["HyDE Enhancement
        Generate Hypothetical Document"]
        Q(["User Query"])
        EMB["baai/bge-m3 Embedding"]
        DENSE["Dense Retrieval
        FAISS Cosine Similarity
        weight = 0.6"]
        SPARSE["Sparse Retrieval
        BM25 Index
        k1=1.5 · b=0.75 · weight=0.4"]
        NORM["Score Normalization"]
        FUSE["Hybrid Fusion Score"]
        MMR["MMR Reranking
        λ=0.5 · target=8~12
        Document Deduplication via MD5 Hash"]
        RES["Classified Retrieval Results
        code: top-5 · text: top-2"]
  end
    A(["GitHub URL / Local Path"]) --> B["Git Clone"]
    B --> C
    C -- Code Files --> E
    C -- Text Files --> F
    E --> G
    F --> G
    G --> I
    I --> J
    K --> K1 & K2
    K1 --> L
    K2 --> L
    L --> M
    M --> N
    N --> WS
    B3 --> WS
    WS --> WC
    Q --> HyDE & SPARSE
    HyDE --> EMB
    EMB --> DENSE
    DENSE --> NORM
    SPARSE --> NORM
    NORM --> FUSE
    FUSE --> MMR
    MMR --> RES
    J -.-> Retrieval
    N -.-> WikiGen
    B -.-> K & B3


[
  {
    "id": "py_agent_graph",
    "pattern": "AgentGraphRunner",
    "is_regex": false,
    "file_pattern": "*.py",
    "min_matches": 1,
    "path_must_contain": "src/agent/graph.py"
  },
  {
    "id": "grep_tool_class",
    "pattern": "class GrepSearchTool",
    "is_regex": false,
    "file_pattern": "*.py",
    "min_matches": 1,
    "path_must_contain": "src/agent/tools/grep_tool.py"
  },
  {
    "id": "fastapi_route",
    "pattern": "/agent/chat",
    "is_regex": false,
    "file_pattern": "*.py",
    "min_matches": 1,
    "path_must_contain": "scripts/api.py"
  },
  {
    "id": "dockerfile_ripgrep",
    "pattern": "ripgrep",
    "is_regex": false,
    "file_pattern": "Dockerfile",
    "min_matches": 1,
    "path_must_contain": "Dockerfile"
  },
  {
    "id": "prompts_grep_mention",
    "pattern": "grep_search",
    "is_regex": false,
    "file_pattern": "*.py",
    "min_matches": 1,
    "path_must_contain": "src/agent/prompts.py"
  },
  {
    "id": "path_prefix_src",
    "pattern": "def execute",
    "is_regex": false,
    "file_pattern": "*.py",
    "path_prefix": "src/agent/tools",
    "min_matches": 1,
    "path_must_contain": "src/agent/tools/"
  },
  {
    "id": "regex_symbol",
    "pattern": "RAG_SEARCH\\s*=",
    "is_regex": true,
    "file_pattern": "*.py",
    "path_prefix": "src/agent",
    "min_matches": 1,
    "path_must_contain": "state.py"
  },
  {
    "id": "readme_or_docs",
    "pattern": "Agent",
    "is_regex": false,
    "file_pattern": "*.md",
    "min_matches": 1,
    "path_must_contain": ".md"
  }
]
